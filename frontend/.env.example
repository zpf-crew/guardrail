# Frontend (Vite) environment.
# Copy to .env.local for local overrides. Only VITE_-prefixed vars reach the client.

# Backend base URL. Leave UNSET to use the workbench default local backend.
# Set it to call the real API, e.g.:
# VITE_API_BASE_URL=http://127.0.0.1:3000
VITE_API_BASE_URL=

# Use mock workbench data instead of the real backend (for UI-only development).
# VITE_WORKBENCH_USE_MOCK=true
VITE_WORKBENCH_USE_MOCK=
