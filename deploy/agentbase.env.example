DATABASE_URL=postgres://guardrail:<password>@<db-host>:5432/guardrail

GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>
# Optional override. In AgentBase Runtime, deploy/start-container.sh derives
# this from GREENNODE_ENDPOINT_URL when omitted.
# GITHUB_CALLBACK_URL=https://<agentbase-endpoint>/api/auth/github/callback
TOKEN_ENC_KEY=<32-byte-utf8-or-64-hex-or-base64-32-byte-key>

LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=<llm-api-key>
LLM_CHAT_PATH=messages
LLM_THINKER_MODEL=google/gemma-4-31b-it
LLM_CODER_MODEL=qwen/qwen3-5-27b

# Optional URL overrides. In AgentBase Runtime, deploy/start-container.sh
# derives both from GREENNODE_ENDPOINT_URL when omitted.
# FRONTEND_URL=https://<agentbase-endpoint>
# BACKEND_URL=https://<agentbase-endpoint>

SESSION_TTL_DAYS=30
WORKSPACE_DIR=/tmp/guardrail-workspaces
