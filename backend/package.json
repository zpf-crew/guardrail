{
  "name": "guardrail-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "migrate": "tsx src/db/migrate.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint yet'",
    "test": "NODE_ENV=test pnpm run typecheck && node --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "dotenv": "^16.4.7",
    "fastify": "^4.28.0",
    "fastify-plugin": "^4.5.1",
    "pg": "^8.13.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.10",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
